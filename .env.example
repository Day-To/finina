# ── Expense API (server-only) ────────────────────────────────────────────────
# POST /api/expenses writes a daily expense to ONE user's Firestore using the
# Firebase Admin SDK. These are read at runtime by the Nitro server — never
# shipped to the browser. Requires deploying the Node server (not static export).

# The owner account whose data to write to (Firebase Auth UID).
EXPENSE_API_UID=

# Optional shared secret. If set, requests must send it via the `x-api-token`
# header, `Authorization: Bearer <token>`, or `?token=` query. Leave blank for an
# open (secret-URL) endpoint like the old Apps Script webhook.
EXPENSE_API_TOKEN=

# Timezone used when the request omits a date (defaults to Asia/Kolkata).
EXPENSE_API_TZ=Asia/Kolkata

# Currency to stamp when neither the month nor the user settings specify one.
EXPENSE_API_DEFAULT_CURRENCY=INR

# ── Service account credentials (choose ONE) ─────────────────────────────────
# 1) The whole service-account JSON, raw or base64-encoded:
FIREBASE_SERVICE_ACCOUNT=

# 2) …or the individual fields (escape newlines in the key as \n):
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# 3) …or point to a service-account file on disk:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
